{
	"info": {
		"name": "API Alumnos - Materias - Inscripciones",
		"description": "TP Taller de Programación 2\nUsar Authorization > Bearer Token con {{token}}\nHacer Login según el rol que se necesite",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "url",
			"value": "http://localhost:3000"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Usuarios",
			"item": [
				{
					"name": "Login Admin (admin / admin123)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"usuario\": \"admin\",\n  \"pass\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{url}}/usuarios/login",
							"host": ["{{url}}"],
							"path": ["usuarios", "login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token de ADMIN guardado');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Login Coordinador (coord1 / 1234)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"usuario\": \"coord1\",\n  \"pass\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{url}}/usuarios/login",
							"host": ["{{url}}"],
							"path": ["usuarios", "login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token de COORDINADOR guardado');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Login Alumno (alumno1 / 1234)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"usuario\": \"alumno1\",\n  \"pass\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{url}}/usuarios/login",
							"host": ["{{url}}"],
							"path": ["usuarios", "login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token de ALUMNO guardado');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Cerrar Sesion (borra el token)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{url}}",
							"host": ["{{url}}"],
							"path": [""]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.collectionVariables.set('token', '');",
									"console.log('Token eliminado - sesion cerrada');"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Crear Usuario (sin token - acceso libre)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Coordinador 1\",\n  \"mail\": \"coord1@test.com\",\n  \"usuario\": \"coord1\",\n  \"pass\": \"1234\",\n  \"id_rol\": 2\n}"
						},
						"url": {
							"raw": "{{url}}/usuarios",
							"host": ["{{url}}"],
							"path": ["usuarios"]
						}
					}
				}
			]
		},
		{
			"name": "Alumnos",
			"item": [
				{
					"name": "Listar Alumnos (activos)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{url}}/alumnos",
							"host": ["{{url}}"],
							"path": ["alumnos"]
						}
					}
				},
				{
					"name": "Listar Alumnos (todos, con ?todos=true)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{url}}/alumnos?todos=true",
							"host": ["{{url}}"],
							"path": ["alumnos"],
							"query": [
								{
									"key": "todos",
									"value": "true"
								}
							]
						}
					}
				},
				{
					"name": "Ver Alumno por ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{url}}/alumnos/1",
							"host": ["{{url}}"],
							"path": ["alumnos", "1"]
						}
					}
				},
				{
					"name": "Crear Alumno (solo Admin)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Alumno 1\",\n  \"mail\": \"alumno1@test.com\",\n  \"usuario\": \"alumno1\",\n  \"pass\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{url}}/alumnos",
							"host": ["{{url}}"],
							"path": ["alumnos"]
						}
					}
				},
				{
					"name": "Editar Alumno (Admin o el mismo alumno)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Alumno 1 Modificado\",\n  \"mail\": \"alumno1mod@test.com\"\n}"
						},
						"url": {
							"raw": "{{url}}/alumnos/1",
							"host": ["{{url}}"],
							"path": ["alumnos", "1"]
						}
					}
				},
				{
					"name": "Baja Logica Alumno (solo Admin)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{url}}/alumnos/1",
							"host": ["{{url}}"],
							"path": ["alumnos", "1"]
						}
					}
				}
			]
		},
